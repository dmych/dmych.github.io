STYLE_SETTINGS_BODY_CLASSES=mod-macos is-frameless is-hidden-frameless obsidian-app theme-light auto-full-screen show-ribbon show-view-header css-settings-manager minimal-theme minimal-readable minimal-light minimal-default-light minimal-dark minimal-default-dark links-int-on links-ext-on full-width-media img-grid minimal-folding chart-default-width table-default-width img-default-width iframe-default-width map-default-width folder-notes-plugin folder-note-underline folder-note-underline-path fn-whitespace-stop-collapsing fn-ignore-attachment-folder version-1-7-2 pdf-plus-click-embed-to-open-link pdf-plus-backlink-selection-highlight is-fullscreen AT-row hide-pdf-embed-toolbar hide-pdf-toolbar-in-hover-editor callouts-default trim-cols embed-hide-title h1-l h2-l h3-l h4-l h5-l h6-l checkbox-square pdf-seamless-on pdf-invert-dark pdf-blend-light sidebar-tabs-default tab-names-off vault-profile-default ribbon-hidden maximize-tables-off tabs-default tab-stack-top minimal-tab-title-hover default hide-folder-note is-focused
